<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Current Status -->
    <TextView
        android:id="@+id/currentStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Current: 20.5°C → Target: 21.0°C"
        android:textSize="14sp"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_marginBottom="24dp"
        android:textAlignment="center"/>

    <!-- Temperature Control -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Temperature"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/tempMinus"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="−"
            android:textSize="32sp"
            style="@style/Widget.Material3.Button.TonalButton"/>

        <TextView
            android:id="@+id/tempDisplay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="20.0°C"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:textColor="?attr/colorPrimary"/>

        <Button
            android:id="@+id/tempPlus"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="+"
            android:textSize="32sp"
            style="@style/Widget.Material3.Button.TonalButton"/>

    </LinearLayout>

    <!-- Duration Control -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Duration"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/durationMinus"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="−"
            android:textSize="32sp"
            style="@style/Widget.Material3.Button.TonalButton"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/durationDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1h 30m"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textColor="?attr/colorPrimary"/>

            <TextView
                android:id="@+id/durationSubtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Until 14:30"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/durationPlus"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="+"
            android:textSize="32sp"
            style="@style/Widget.Material3.Button.TonalButton"/>

    </LinearLayout>

    <!-- Quick Duration Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/duration1h"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="1h"
            android:textSize="11sp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <Button
            android:id="@+id/duration2h"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="2h"
            android:textSize="11sp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <Button
            android:id="@+id/duration4h"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="4h"
            android:textSize="11sp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <Button
            android:id="@+id/durationPermanent"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="∞"
            android:textSize="16sp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/followScheduleButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Follow Schedule"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.TonalButton"/>

        <Button
            android:id="@+id/applyButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Apply"
            android:textSize="12sp"
            android:backgroundTint="#4CAF50"
            style="@style/Widget.Material3.Button"/>

    </LinearLayout>

</LinearLayout>