<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="0dp"
    android:background="@drawable/widget_background">

    <!-- Header Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1976D2"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">
        
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Evohome"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.02"/>
        
        <ImageButton
            android:id="@+id/refreshButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_refresh"
            android:background="@drawable/header_button_bg"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:contentDescription="Refresh"/>
    </LinearLayout>

    <!-- 2x2 Grid for Zones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">
        
        <!-- Top Row: Zone 1 & 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            
            <!-- Zone 1 Quadrant -->
            <LinearLayout
                android:id="@+id/zone1Container"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="10dp"
                android:background="@drawable/zone_card_bg"
                android:layout_margin="4dp"
                android:gravity="center">
                
                <TextView
                    android:id="@+id/zone1Name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Living Room"
                    android:textSize="11sp"
                    android:textColor="#424242"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:layout_marginBottom="4dp"/>
                
                <TextView
                    android:id="@+id/zone1Temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20.5"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"/>
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="6dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:layout_marginEnd="2dp"/>
                    
                    <TextView
                        android:id="@+id/zone1Target"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="21.0"
                        android:textSize="13sp"
                        android:textColor="#757575"
                        android:textStyle="bold"/>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="°C"
                        android:textSize="11sp"
                        android:textColor="#757575"/>
                </LinearLayout>
                
                <ImageButton
                    android:id="@+id/zone1Boost"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_boost"
                    android:background="@drawable/boost_button_bg"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:contentDescription="Boost Zone 1"/>
            </LinearLayout>
            
            <!-- Zone 2 Quadrant -->
            <LinearLayout
                android:id="@+id/zone2Container"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="10dp"
                android:background="@drawable/zone_card_bg"
                android:layout_margin="4dp"
                android:gravity="center">
                
                <TextView
                    android:id="@+id/zone2Name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bedroom"
                    android:textSize="11sp"
                    android:textColor="#424242"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:layout_marginBottom="4dp"/>
                
                <TextView
                    android:id="@+id/zone2Temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="19.0"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"/>
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="6dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:layout_marginEnd="2dp"/>
                    
                    <TextView
                        android:id="@+id/zone2Target"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="20.0"
                        android:textSize="13sp"
                        android:textColor="#757575"
                        android:textStyle="bold"/>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="°C"
                        android:textSize="11sp"
                        android:textColor="#757575"/>
                </LinearLayout>
                
                <ImageButton
                    android:id="@+id/zone2Boost"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_boost"
                    android:background="@drawable/boost_button_bg"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:contentDescription="Boost Zone 2"/>
            </LinearLayout>
        </LinearLayout>
        
        <!-- Bottom Row: Zone 3 & 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            
            <!-- Zone 3 Quadrant -->
            <LinearLayout
                android:id="@+id/zone3Container"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="10dp"
                android:background="@drawable/zone_card_bg"
                android:layout_margin="4dp"
                android:gravity="center">
                
                <TextView
                    android:id="@+id/zone3Name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Kitchen"
                    android:textSize="11sp"
                    android:textColor="#424242"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:layout_marginBottom="4dp"/>
                
                <TextView
                    android:id="@+id/zone3Temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="18.5"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"/>
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="6dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:layout_marginEnd="2dp"/>
                    
                    <TextView
                        android:id="@+id/zone3Target"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="19.0"
                        android:textSize="13sp"
                        android:textColor="#757575"
                        android:textStyle="bold"/>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="°C"
                        android:textSize="11sp"
                        android:textColor="#757575"/>
                </LinearLayout>
                
                <ImageButton
                    android:id="@+id/zone3Boost"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_boost"
                    android:background="@drawable/boost_button_bg"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:contentDescription="Boost Zone 3"/>
            </LinearLayout>
            
            <!-- Zone 4 Quadrant -->
            <LinearLayout
                android:id="@+id/zone4Container"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="10dp"
                android:background="@drawable/zone_card_bg"
                android:layout_margin="4dp"
                android:gravity="center">
                
                <TextView
                    android:id="@+id/zone4Name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bathroom"
                    android:textSize="11sp"
                    android:textColor="#424242"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:layout_marginBottom="4dp"/>
                
                <TextView
                    android:id="@+id/zone4Temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21.0"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"/>
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="6dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:layout_marginEnd="2dp"/>
                    
                    <TextView
                        android:id="@+id/zone4Target"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="22.0"
                        android:textSize="13sp"
                        android:textColor="#757575"
                        android:textStyle="bold"/>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="°C"
                        android:textSize="11sp"
                        android:textColor="#757575"/>
                </LinearLayout>
                
                <ImageButton
                    android:id="@+id/zone4Boost"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_boost"
                    android:background="@drawable/boost_button_bg"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:contentDescription="Boost Zone 4"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>