<resources>
    <style name="AppTheme" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Red Brand Color -->
        <item name="colorPrimary">@color/evohome_red</item>
        <item name="colorPrimaryVariant">@color/evohome_red_dark</item>
        <item name="colorOnPrimary">@color/text_white</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/evohome_red_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Background -->
        <item name="android:colorBackground">@color/background_light</item>
        
        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary_black</item>
        <item name="android:textColorSecondary">@color/text_secondary_grey</item>
    </style>
   
   <style name="DialogActivityTheme" parent="Theme.AppCompat.Light.Dialog">
       <item name="android:windowIsFloating">true</item>
       <item name="android:windowCloseOnTouchOutside">true</item>
       <item name="android:windowBackground">@android:color/transparent</item>
       <item name="android:windowIsTranslucent">true</item>
       <item name="android:backgroundDimEnabled">true</item>
   </style>

   <style name="ToolbarTheme" parent="ThemeOverlay.Material3.Dark">
       <item name="colorControlNormal">@android:color/white</item>
   </style>
</resources>